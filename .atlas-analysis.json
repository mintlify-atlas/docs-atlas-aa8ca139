  "keyFeatures": [
    "Realtime P2P state synchronization",
    "Graph data structure supporting key/value, tables, documents, and relations",
    "Local-first and offline-capable",
    "Decentralized architecture with no single point of failure",
    "End-to-end encryption via SEA (Security, Encryption, Authorization)",
    "CRDT-based conflict resolution",
    "Cross-platform (Browser, Node.js, React Native, Electron)",
    "Pluggable storage adapters (IndexedDB, LocalStorage, S3, custom)",
    "High performance (20M+ API ops/sec)",
    "Lightweight (9KB gzipped)"
  ],
